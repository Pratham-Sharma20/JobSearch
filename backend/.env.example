# ============================================================
# Server
# ============================================================
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ============================================================
# MongoDB Atlas
# ============================================================
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ============================================================
# JWT
# ============================================================
JWT_ACCESS_SECRET=CHANGE_ME_generate_a_random_string_at_least_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_different_random_string_32_chars
JWT_REFRESH_EXPIRES=30d

# ============================================================
# Google OAuth
# ============================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ============================================================
# Redis (Upstash or local)
# ============================================================
# Upstash Redis: redis://default:<password>@<host>:<port>
# Local Redis:   redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ============================================================
# Typesense
# ============================================================
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=your_typesense_admin_api_key

# ============================================================
# Frontend URL (CORS)
# ============================================================
FRONTEND_URL=http://localhost:5173

# ============================================================
# Resend (Email)
# ============================================================
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# Telegram Bot
# ============================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ============================================================
# Discord
# ============================================================
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
